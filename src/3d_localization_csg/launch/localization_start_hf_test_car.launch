<launch>
    <!-- <node pkg="rviz" type="rviz" name="rviz_filter" args="-d $(find loc_ad)/rviz/filtering.rviz"></node> -->
    <arg name="pre_config_path" default="$(find loc_ad)/config/pretreat"/>
    <node pkg="loc_ad" type="data_pretreat_node" name="data_pretreat_node" output="screen">
        <param name="config_file" value="$(arg pre_config_path)/pretreat.yaml"/>
    </node>
    <arg name="filter_config_path" default="$(find loc_ad)/config/filtering"/>
    <node pkg="loc_ad" type="filtering_node" name="filtering_node" output="screen">
        <param name="config_file" value="$(arg filter_config_path)/filtering.yaml"/>
    </node>

    <!--- Robot State TF -->
    <include file="$(find loc_ad)/launch/include/state_publisher_loc_hf_test_car.launch" />

    <node pkg="nodelet" type="nodelet" name="pcl_manager" args="manager" output="screen" />
    <node pkg="nodelet" type="nodelet" name="passthrough" args="load pcl/PassThrough pcl_manager" output="screen">
        <remap from="~input" to="/rslidar_points" />
        <remap from="/passthrough/output" to="/velodyne_points" />
        <rosparam>
            filter_field_name: z
            filter_limit_min: -80
            filter_limit_max: 80
            filter_limit_negative: False
        </rosparam>
        <rosparam>
            filter_field_name: x
            filter_limit_min: -80
            filter_limit_max: 80
            filter_limit_negative: False
        </rosparam>
        <rosparam>
            filter_field_name: y
            filter_limit_min: -80
            filter_limit_max: 80
            filter_limit_negative: False
        </rosparam>
    </node>
</launch>