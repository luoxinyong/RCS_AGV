<launch>
    <!-- <node pkg="rviz"  type="rviz"  name="rviz_filter"  args="-d $(find loc_ad)/rviz/filtering.rviz"></node> -->
    <node pkg="loc_ad"  type="data_pretreat_node"    name="data_pretreat_node"    output="screen"></node>
    <node pkg="loc_ad"  type="filtering_node"        name="filtering_node"        output="screen"></node>

    <!--- Robot State TF -->
    <include file="$(find loc_ad)/launch/include/state_publisher_loc_hf_heli_car.launch" />

    <node pkg="nodelet" type="nodelet" name="pcl_manager" args="manager" output="screen" />
    <node pkg="nodelet" type="nodelet" name="passthrough" args="load pcl/PassThrough pcl_manager" output="screen">
        <remap from="~input" to="/rslidar_points" />
        <remap from="/passthrough/output" to="/velodyne_points" />
        <rosparam>
            filter_field_name: z
            filter_limit_min: -80
            filter_limit_max: 80
            filter_limit_negative: False
        </rosparam>
        <rosparam>
            filter_field_name: x
            filter_limit_min: -80
            filter_limit_max: 80
            filter_limit_negative: False
        </rosparam>
        <rosparam>
            filter_field_name: y
            filter_limit_min: -80
            filter_limit_max: 80
            filter_limit_negative: False
        </rosparam>
    </node>
</launch>